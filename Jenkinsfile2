##with K8S Stage

pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_IMAGE = 'sumanraj07/bms:latest'
        EKS_CLUSTER_NAME = 'suman-eks'
        AWS_REGION = 'us-east-1'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: 'https://github.com/msuman-07/Book-My-Show.git'
                sh 'ls -la'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=BMS \
                        -Dsonar.projectKey=BMS
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    // Timeout prevents pipeline hanging if SonarQube doesn't respond
                    timeout(time: 2, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: false, credentialsId: 'Sonar-token'
                    }
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd bookmyshow-app
                ls -la

                if [ -f package.json ]; then
                    rm -rf node_modules package-lock.json
                    npm install --legacy-peer-deps
                else
                    echo "Error: package.json not found!"
                    exit 1
                fi
                '''
            }
        }

        stage('OWASP FS Scan') {
            steps {
                // catchError keeps pipeline going even if OWASP scan fails
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    dependencyCheck additionalArguments: '''
                        --scan ./
                        --disableYarnAudit
                        --disableNodeAudit
                        --noupdate
                    ''', odcInstallation: 'DP-Check'
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }

        stage('Trivy FS Scan') {
            steps {
                // || true prevents pipeline failure if vulnerabilities are found
                sh 'trivy fs . > trivyfs.txt || true'
            }
        }

        stage('Docker Build & Push') {
            options {
                // Prevent hanging if Docker build takes too long
                timeout(time: 30, unit: 'MINUTES')
            }
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker') {
                        sh '''
                        echo "Building Docker image..."
                        docker build --no-cache \
                            -t $DOCKER_IMAGE \
                            -f bookmyshow-app/Dockerfile bookmyshow-app

                        echo "Pushing Docker image to Docker Hub..."
                        docker push $DOCKER_IMAGE
                        '''
                    }
                }
            }
        }

        stage('Deploy to EKS Cluster') {
            steps {
                script {
                    sh '''
                    echo "Verifying AWS credentials..."
                    aws sts get-caller-identity

                    echo "Configuring kubectl for EKS cluster..."
                    aws eks update-kubeconfig --name $EKS_CLUSTER_NAME --region $AWS_REGION

                    echo "Checking Kubernetes context..."
                    kubectl config view

                    echo "Deploying application to EKS..."
                    kubectl apply -f deployment.yml
                    kubectl apply -f service.yml

                    echo "Checking deployment status..."
                    kubectl get pods
                    kubectl get svc
                    '''
                }
            }
        }

    }

    // post block is correctly OUTSIDE stages and INSIDE pipeline
    post {

        success {
            emailext(
                subject: "✅ SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build SUCCESSFUL

Project:      ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Docker Image: ${env.DOCKER_IMAGE}
Build URL:    ${env.BUILD_URL}
                """,
                to: "msuman2003711@gmail.com"
            )
        }

        failure {
            emailext(
                subject: "❌ FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Build FAILED

Project:      ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Please check Jenkins console logs.
Build URL:    ${env.BUILD_URL}
                """,
                to: "msuman2003711@gmail.com"
            )
        }

        always {
            emailext(
                attachLog: true,
                subject: "Build ${currentBuild.currentResult}: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
Project:      ${env.JOB_NAME}
Build Number: ${env.BUILD_NUMBER}
Build Result: ${currentBuild.currentResult}
Build URL:    ${env.BUILD_URL}
                """,
                to: "msuman2003711@gmail.com",
                attachmentsPattern: 'trivyfs.txt'
            )
        }

    }

}
